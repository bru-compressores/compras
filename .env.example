# Copie este arquivo para .env e preencha os valores

# PostgreSQL Supabase (obrigatório em produção)
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@[HOST].supabase.co:5432/postgres

# JWT Secret (troque por uma string aleatória longa)
JWT_SECRET=sua-chave-secreta-muito-longa-aqui

# Porta (Render define automaticamente)
PORT=3000
